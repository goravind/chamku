# Supabase - create a project at https://supabase.com
# Then run supabase/schema.sql in the SQL Editor
# Create a storage bucket named "attachments" (Public or with RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI - for AI-generated subtasks (optional, from https://platform.openai.com/api-keys)
# Without this, the chat will parse your typed list (one per line or comma-separated)
VITE_OPENAI_API_KEY=sk-...
